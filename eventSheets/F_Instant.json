										{
											"id": "set-eventvar-value",
											"objectClass": "System",
											"sid": 139168553593547,
											"parameters": {
												"variable": "playerData",
												"value": "DICT_SaveGame.AsJSON"
											}
										},
										{
											"type": "script",
											"language": "javascript",
											"script": [
												"const DEFAULT_DATA = {",
												"    data: runtime.globalVars.playerData,",
												"}",
												"",
												"FBInstant.player",
												"    .getDataAsync([\"data\"])",
												"    .then((data) => {",
												"        if (data[\"data\"] === undefined) {",
												"            console.log('data is undefined');",
												"            data = DEFAULT_DATA;",
												"        }",
												"        //console.log(\"loaded    === \", data[\"data\"])",
												"",
												"        if (typeof data[\"data\"] == \"string\") {",
												"            runtime.globalVars.playerData = data[\"data\"];",
												"        } else {",
												"            runtime.globalVars.playerData = JSON.stringify(data[\"data\"]);",
												"        }",
												"        //console.log(\"PlayerData    === \", runtime.globalVars.PlayerData)",
												"        runtime.callFunction(\"getConnectedPlayersAsync\");",
												"        runtime.callFunction(\"canSaveGame\");",
												"        runtime.globalVars.canSaveGame = 1;",
												"    }).catch(error => {",
												"        console.error(\"getDataAsync\", error)",
												"        runtime.callFunction(\"getConnectedPlayersAsync\");",
												"        runtime.globalVars.canSaveGame = 0;",
												"",
												"    });"
											]
										}
									],
									"sid": 396810616888587
								}
