			"children": [
				{
					"functionName": "a2u",
					"functionDescription": "",
					"functionCategory": "",
					"functionReturnType": "none",
					"functionCopyPicked": false,
					"functionIsAsync": false,
					"functionParameters": [],
					"eventType": "function-block",
					"conditions": [],
					"actions": [],
					"sid": 515542146159033,
					"children": [
						{
							"eventType": "block",
							"conditions": [],
							"actions": [
								{
									"type": "script",
									"language": "javascript",
									"script": [
										"FBInstant.player.getASIDAsync().then(",
										"            _asid => {",
										"                cancel_all_notifications(_asid);",
										"            }",
										"        );",
										"\t\t",
										"function cancel_all_notifications(asid){",
										"        FBInstant.graphApi.requestAsync(",
										"            \"/\" + asid + \"/cancel_all_notifications\",",
										"            \"POST\"",
										"        )",
										"        .then((result) => {",
										"            console.log(\"resetSendA2u: \", result);",
										"            sendNewA2U(asid);",
										"        })",
										"        .catch((error) => {",
										"            console.log(\"error send a2u : \", error);",
										"            sendNewA2U(asid);",
										"        });",
										"    }",
										"\t",
										"function sendNewA2U(asid){",
										"        let DAYS = [1, 2, 3, 4, 5, 6];",
										"            for (let i = 0; i < DAYS.length; i++) {",
										"                let delayTime = 60 * 5 * 1;",
										"\t\t\t\t",
										"                if(DAYS[i] > 0) {",
										"                    delayTime = 86400  * DAYS[i];",
										"                };",
										"                let messageData = {",
										"\t\t\t\t\tmessage: {",
										"\t\t\t\t\t\ttitle: runtime.callFunction(\"a2u_getdata\", i, \"title\"),",
										"\t\t\t\t\t\tbody: runtime.callFunction(\"a2u_getdata\", i, \"body\"),",
										"\t\t\t\t\t\tmedia_url: runtime.callFunction(\"a2u_getdata\", i, \"photo\"),",
										"\t\t\t\t\t\t",
										"\t\t\t\t\t}, schedule_interval: delayTime",
										"\t\t\t\t};",
										"                FBInstant.graphApi",
										"                    .requestAsync(",
										"                        \"/\" + asid + \"/notifications\",",
										"                        \"POST\",",
										"                        messageData",
										"                    )",
